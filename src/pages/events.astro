---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventsContent from '../components/EventsContent.astro';
import { tEvents } from '../data/translations';

const locale = 'sk';
const t = tEvents(locale);
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
const base = siteBase;
---

<BaseLayout title={t.title} description={t.upcoming} locale={locale} current="events">
  <EventsContent locale={locale} base={base} />
</BaseLayout>
