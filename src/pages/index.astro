---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePageContent from '../components/HomePageContent.astro';
import { tHome } from '../data/translations';

const locale = 'sk';
const t = tHome(locale);
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
const base = siteBase;
---

<BaseLayout title={t.title} description={t.intro} locale={locale} current="home" fullTextile preloadHero>
  <HomePageContent locale={locale} siteBase={siteBase} base={base} />
</BaseLayout>
