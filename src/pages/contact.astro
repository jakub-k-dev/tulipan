---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactContent from '../components/ContactContent.astro';
import { tContact } from '../data/translations';

const locale = 'sk';
const t = tContact(locale);
---

<BaseLayout title={t.title} description={t.formNote} locale={locale} current="contact">
  <ContactContent locale={locale} />
</BaseLayout>
