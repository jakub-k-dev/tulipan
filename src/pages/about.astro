---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutContent from '../components/AboutContent.astro';
import { tAbout } from '../data/translations';

const locale = 'sk';
const t = tAbout(locale);
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
---

<BaseLayout title={t.title} description={t.bodyParagraphs[0].slice(0, 155)} locale={locale} current="about">
  <AboutContent locale={locale} siteBase={siteBase} />
</BaseLayout>
