---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTextileHero from '../../components/PageTextileHero.astro';
import { tAbout, tTimeline } from '../../data/translations';

const locale = 'en';
const t = tAbout(locale);
const timelineEntries = tTimeline(locale);
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
---

<BaseLayout title={t.title} description={t.body.slice(0, 155)} locale={locale} current="about">
  <PageTextileHero title={t.title} />
  <div class="relative bg-textile-cream">
    <div class="max-w-[90rem] w-full mx-auto px-4 py-12">
      <figure class="rounded-xl overflow-hidden border-2 border-textile-gold/50 shadow-lg max-w-2xl">
        <img src={`${siteBase || ''}/images/gallery/group-photo.png`} alt="Tulipan folklore group members" class="w-full h-auto object-cover" width="800" height="600" loading="eager" />
      </figure>
      <div class="mt-8 pl-4 border-l-4 border-embroidery-red max-w-2xl text-heritage-charcoal leading-relaxed font-medium">
        <p>{t.body}</p>
      </div>

      <section class="mt-16 pt-12 border-t border-textile-gold/40" aria-labelledby="history-heading">
        <h2 id="history-heading" class="font-display text-2xl md:text-3xl text-heritage-charcoal font-semibold">{t.historyTitle}</h2>
        <p class="mt-2 text-heritage-charcoal/85 text-sm max-w-2xl">{t.historyIntro}</p>
        <div class="mt-8 relative pl-6 md:pl-8">
          <span class="absolute left-0 top-2 bottom-2 w-0.5 bg-embroidery-red/50 rounded-full" aria-hidden="true" />
          <ul class="relative space-y-0" role="list">
            {timelineEntries.map((entry) => (
              <li class="flex flex-col sm:flex-row sm:gap-6 gap-1 pb-8 last:pb-0">
                <span class="absolute left-[-1.5rem] md:left-[-2rem] top-0.25 w-3 h-3 rounded-full bg-embroidery-red border-2 border-textile-cream shadow shrink-0" aria-hidden="true" />
                <span class="font-display font-semibold text-embroidery-red text-sm sm:w-24 shrink-0">{entry.year}</span>
                <span class="text-heritage-charcoal font-medium">{entry.text}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
