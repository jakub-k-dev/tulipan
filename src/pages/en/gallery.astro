---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryContent from '../../components/GalleryContent.astro';
import { tGallery } from '../../data/translations';

const locale = 'en';
const t = tGallery(locale);
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
---

<BaseLayout title={t.title} description={t.placeholder} locale={locale} current="gallery">
  <GalleryContent locale={locale} siteBase={siteBase} />
</BaseLayout>
