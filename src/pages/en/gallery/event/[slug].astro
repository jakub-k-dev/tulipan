---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PageTextileHero from '../../../../components/PageTextileHero.astro';
import { galleryEvents } from '../../../../data/gallery';
import { tGallery, tSite } from '../../../../data/translations';

export function getStaticPaths() {
  return galleryEvents.map((event) => ({ params: { slug: event.slug } }));
}

const { slug } = Astro.params;
const locale = 'en';
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
const t = tGallery(locale);
const siteT = tSite(locale);
const galleryPath = siteBase ? `${siteBase}/en/gallery` : '/en/gallery';
---

<BaseLayout title={t.title} description={t.placeholder} locale={locale} current="gallery">
  <PageTextileHero title={t.title} />
  <div class="bg-textile-cream">
    <div class="max-w-[90rem] w-full mx-auto px-4 py-12">
      <a href={galleryPath} class="inline-flex items-center text-embroidery-crimson font-medium hover:underline mb-6 focus:outline-none focus:ring-2 focus:ring-embroidery-crimson rounded">
        {t.backToGallery}
      </a>
      <div class="max-w-2xl pl-4 border-l-4 border-textile-gold text-heritage-charcoal leading-relaxed font-medium">
        <p>{siteT.constructionMessage}</p>
      </div>
    </div>
  </div>
</BaseLayout>
