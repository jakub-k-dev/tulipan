---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TraditionsContent from '../../components/TraditionsContent.astro';
import { tTraditions } from '../../data/translations';

const locale = 'en';
const t = tTraditions(locale);
---

<BaseLayout title={t.title} description={t.heritageBody.slice(0, 155)} locale={locale} current="traditions">
  <TraditionsContent locale={locale} />
</BaseLayout>
