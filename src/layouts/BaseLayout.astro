---
import type { Locale } from '../data/translations';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  current: string;
  /** If true, main is not wrapped in a background strip; page provides full textile layout */
  fullTextile?: boolean;
  /** If true, preload hero image for LCP (homepage only) */
  preloadHero?: boolean;
}

const { title, description, locale, current, fullTextile = false, preloadHero = false } = Astro.props;
const lang = locale === 'sk' ? 'sk' : 'en';
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || ''; // '' or '/tulipan'
const goatCounterSite = import.meta.env.PUBLIC_GOATCOUNTER_SITE as string | undefined;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const pathWithoutBase = siteBase ? pathname.replace(siteBase, '') || '/' : pathname;
const enUrl = locale === 'en' ? pathname : `${siteBase}/en${pathWithoutBase === '/' ? '' : pathWithoutBase}`;
const skUrl = locale === 'sk' ? pathname : (siteBase ? pathname.replace(`${siteBase}/en`, siteBase) : pathname.replace(/^\/en/, '')) || siteBase || '/';
const siteOrigin = (typeof Astro.site === 'string' ? Astro.site.replace(/\/$/, '') : null) ?? Astro.url.origin;
const canonicalHref = new URL(pathname, siteOrigin).href;
const ogImagePath = `${siteBase || ''}/images/hero/hero-background.jpg`;
const ogImageUrl = new URL(ogImagePath.startsWith('/') ? ogImagePath : `/${ogImagePath}`, siteOrigin).href;
const fullTitle = `${title} — Tulipán`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <style is:global set:html>{`:root { --hero-bg-url: url('${siteBase || ''}/images/hero/hero-background.jpg'); --hero-bg-url-webp: url('${siteBase || ''}/images/hero/hero-background.webp'); }`}</style>
    {preloadHero && <link rel="preload" as="image" href={`${siteBase || ''}/images/hero/hero-background.avif`} type="image/avif" fetchpriority="high" />}
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${siteBase || ''}/images/logo.svg`} />
    <link rel="apple-touch-icon" href={`${siteBase || ''}/images/logo.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalHref} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'sk' ? 'sk_SK' : 'en_GB'} />
    <meta property="og:site_name" content="Tulipán Čataj" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" hreflang="sk" href={new URL(skUrl, Astro.url).href} />
    <link rel="alternate" hreflang="en" href={new URL(enUrl, Astro.url).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(skUrl, Astro.url).href} />
    <link rel="prefetch" href={locale === 'sk' ? `${siteBase}/about` : `${siteBase}/en/about`} />
    <link rel="prefetch" href={locale === 'sk' ? `${siteBase}/events` : `${siteBase}/en/events`} />
    {goatCounterSite && (
      <script
        data-goatcounter={`https://${goatCounterSite}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      />
    )}
  </head>
  <body class="min-h-screen flex flex-col text-heritage-charcoal font-body">
    <Header locale={locale} current={current} />
    <main class={fullTextile ? 'flex-1' : 'flex-1 bg-textile-cream'}>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
