---
import type { Locale } from '../data/translations';
import PageTextileHero from './PageTextileHero.astro';
import { tTraditions, tTimeline } from '../data/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = tTraditions(locale);
const timelineEntries = tTimeline(locale);
---

<PageTextileHero title={t.title} />
<div class="bg-textile-cream w-full">
  <div class="w-full px-4 sm:px-6 lg:px-8 py-12 max-w-[100rem] mx-auto">
    <section class="max-w-3xl">
      <h2 class="font-display text-xl text-heritage-charcoal font-semibold">{t.heritageTitle}</h2>
      <p class="mt-4 text-heritage-charcoal leading-relaxed">{t.heritageBody}</p>
    </section>

    <section class="mt-16 pt-12 border-t border-textile-gold/40" aria-labelledby="history-heading">
      <h2 id="history-heading" class="font-display text-2xl md:text-3xl text-heritage-charcoal font-semibold">{t.historyTitle}</h2>
      <p class="mt-2 text-heritage-charcoal/85 text-sm">{t.historyIntro}</p>
      <div class="mt-8 relative pl-6 md:pl-8">
        <span class="absolute left-0 top-2 bottom-2 w-0.5 bg-embroidery-red/50 rounded-full" aria-hidden="true" />
        <ul class="relative space-y-0" role="list">
          {timelineEntries.map((entry) => (
            <li class="flex flex-col sm:flex-row sm:gap-8 gap-1 pb-8 last:pb-0">
              <span class="absolute left-[-1.5rem] md:left-[-2rem] top-0.25 w-3 h-3 rounded-full bg-embroidery-red border-2 border-textile-cream shadow shrink-0" aria-hidden="true" />
              <span class="font-display font-semibold text-embroidery-red text-sm sm:w-28 shrink-0">{entry.year}</span>
              <span class="text-heritage-charcoal font-medium pr-4">{entry.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</div>
