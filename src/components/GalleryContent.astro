---
import type { Locale } from '../data/translations';
import PageTextileHero from './PageTextileHero.astro';
import { tGallery } from '../data/translations';
import { galleryEvents, getEventImages, formatGalleryDate } from '../data/gallery';
import { galleryDisplaySrc } from '../data/gallery';

interface Props {
  locale: Locale;
  siteBase: string;
}

const { locale, siteBase } = Astro.props;
const t = tGallery(locale);
const galleryPath = locale === 'en' ? `${siteBase}/en/gallery` : `${siteBase || ''}/gallery`.replace(/\/$/, '') || '/gallery';
---

<PageTextileHero title={t.title} noFixed />
<div class="z-10 bg-textile-cream page-content-fill">
  <div class="max-w-[90rem] w-full mx-auto px-4 py-12">
    <h2 class="text-2xl font-display font-semibold text-heritage-charcoal mb-10">{t.timelineTitle}</h2>
    <div class="relative">
      <div class="absolute left-2 top-0 bottom-0 w-2 bg-embroidery-ochre/70 pointer-events-none md:left-1/2 md:-translate-x-1" aria-hidden="true" />
      <div class="flex flex-col gap-3 pl-8 md:hidden">
        {galleryEvents.map((event) => {
          const images = getEventImages(event);
          const cover = images[0];
          const displaySrc = cover ? galleryDisplaySrc(cover) : null;
          const title = locale === 'sk' ? event.titleSk : event.titleEn;
          const eventDate = event.date && event.slug !== 'ostatne' ? formatGalleryDate(event.date, locale) : null;
          const eventPath = `${galleryPath}/event/${event.slug}`;
          return (
            <article class="timeline-event-card relative">
              <span class="absolute -left-7 top-4 w-4 h-4 rounded-full bg-embroidery-crimson border-2 border-textile-cream shadow shrink-0" aria-hidden="true" />
              {displaySrc && (
                <a href={eventPath} class="block w-full aspect-video rounded-xl overflow-hidden bg-heritage-charcoal/10 focus:outline-none focus:ring-2 focus:ring-embroidery-crimson">
                  <img src={siteBase ? siteBase + displaySrc : displaySrc} alt="" width="224" height="126" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
                </a>
              )}
              <div class="mt-2">
                {eventDate && <time class="text-sm text-heritage-charcoal/70 font-medium" datetime={event.date}>{eventDate}</time>}
                <h3 class="text-xl font-display font-semibold text-heritage-charcoal mt-0.5">{title}</h3>
                <p class="text-heritage-charcoal/80 mt-1">{images.length} {t.photosCount}</p>
                <a href={eventPath} class="mt-2 inline-flex items-center text-embroidery-crimson font-medium hover:underline focus:outline-none focus:ring-2 focus:ring-embroidery-crimson rounded">
                  {t.openEvent} →
                </a>
              </div>
            </article>
          );
        })}
      </div>
      <div class="hidden md:grid md:grid-cols-[1fr_auto_1fr] md:gap-0">
        <div class="flex flex-col gap-3 md:gap-4 md:pr-4 md:text-right">
          {galleryEvents.filter((_, i) => i % 2 === 0).map((event) => {
            const images = getEventImages(event);
            const cover = images[0];
            const displaySrc = cover ? galleryDisplaySrc(cover) : null;
            const title = locale === 'sk' ? event.titleSk : event.titleEn;
            const eventDate = event.date && event.slug !== 'ostatne' ? formatGalleryDate(event.date, locale) : null;
            const eventPath = `${galleryPath}/event/${event.slug}`;
            return (
              <article class="timeline-event-card">
                {displaySrc && (
                  <a href={eventPath} class="block w-full md:max-w-md lg:max-w-lg md:ml-auto aspect-video rounded-xl overflow-hidden bg-heritage-charcoal/10 focus:outline-none focus:ring-2 focus:ring-embroidery-crimson shadow-lg">
                    <img src={siteBase ? siteBase + displaySrc : displaySrc} alt="" width="384" height="216" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
                  </a>
                )}
                <div class="mt-3 md:ml-auto md:max-w-md lg:max-w-lg">
                  {eventDate && <time class="text-sm text-heritage-charcoal/70 font-medium" datetime={event.date}>{eventDate}</time>}
                  <h3 class="text-xl md:text-2xl font-display font-semibold text-heritage-charcoal mt-0.5">{title}</h3>
                  <p class="text-heritage-charcoal/80 mt-1">{images.length} {t.photosCount}</p>
                  <a href={eventPath} class="mt-2 inline-flex items-center text-embroidery-crimson font-medium hover:underline focus:outline-none focus:ring-2 focus:ring-embroidery-crimson rounded">
                    {t.openEvent} →
                  </a>
                </div>
              </article>
            );
          })}
        </div>
        <div class="flex flex-col h-full min-h-0 z-[1]">
          {galleryEvents.map((event, index) => {
            const year = event.slug !== 'ostatne' ? event.date.slice(0, 4) : null;
            const prevEvent = galleryEvents[index - 1];
            const showYear = year && (!prevEvent || prevEvent.date.slice(0, 4) !== year);
            return (
              <div class="flex-1 min-h-[4rem] flex flex-col items-center justify-center px-1">
                <span class="w-5 h-5 rounded-full bg-embroidery-crimson border-2 border-textile-cream shadow shrink-0" aria-hidden="true" />
                {showYear && (
                  <span class="mt-2 text-sm font-semibold text-heritage-charcoal bg-textile-cream px-2 whitespace-nowrap">
                    {year}
                  </span>
                )}
              </div>
            );
          })}
        </div>
        <div class="flex flex-col gap-3 md:gap-4 md:pl-4 md:pt-[9rem] md:text-left">
          {galleryEvents.filter((_, i) => i % 2 === 1).map((event) => {
            const images = getEventImages(event);
            const cover = images[0];
            const displaySrc = cover ? galleryDisplaySrc(cover) : null;
            const title = locale === 'sk' ? event.titleSk : event.titleEn;
            const eventDate = event.date && event.slug !== 'ostatne' ? formatGalleryDate(event.date, locale) : null;
            const eventPath = `${galleryPath}/event/${event.slug}`;
            return (
              <article class="timeline-event-card">
                {displaySrc && (
                  <a href={eventPath} class="block w-full md:max-w-md lg:max-w-lg md:mr-auto aspect-video rounded-xl overflow-hidden bg-heritage-charcoal/10 focus:outline-none focus:ring-2 focus:ring-embroidery-crimson shadow-lg">
                    <img src={siteBase ? siteBase + displaySrc : displaySrc} alt="" width="384" height="216" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
                  </a>
                )}
                <div class="mt-3 md:mr-auto md:max-w-md lg:max-w-lg">
                  {eventDate && <time class="text-sm text-heritage-charcoal/70 font-medium" datetime={event.date}>{eventDate}</time>}
                  <h3 class="text-xl md:text-2xl font-display font-semibold text-heritage-charcoal mt-0.5">{title}</h3>
                  <p class="text-heritage-charcoal/80 mt-1">{images.length} {t.photosCount}</p>
                  <a href={eventPath} class="mt-2 inline-flex items-center text-embroidery-crimson font-medium hover:underline focus:outline-none focus:ring-2 focus:ring-embroidery-crimson rounded">
                    {t.openEvent} →
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</div>
