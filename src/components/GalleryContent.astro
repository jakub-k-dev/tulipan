---
import type { Locale } from '../data/translations';
import PageTextileHero from './PageTextileHero.astro';
import { tGallery } from '../data/translations';
import { galleryImages, galleryDisplaySrc, formatGalleryDate } from '../data/gallery';

interface Props {
  locale: Locale;
  siteBase: string;
}

const { locale, siteBase } = Astro.props;
const t = tGallery(locale);
---

<PageTextileHero title={t.title} noFixed />
<div class="relative z-10 bg-textile-cream">
  <div class="max-w-[90rem] w-full mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {galleryImages.map((img) => {
        const displaySrc = galleryDisplaySrc(img);
        const alt = locale === 'sk' ? img.altSk : img.altEn;
        return (
          <a href={`${siteBase || ''}${img.src}`} target="_blank" rel="noopener noreferrer" class="gallery-card block rounded-xl overflow-hidden aspect-[4/3] bg-heritage-charcoal/5" title={alt}>
            <img src={`${siteBase || ''}${displaySrc}`} alt={alt} width={img.width} height={img.height} class="w-full h-full object-cover" style={img.rotate ? `transform: rotate(${img.rotate}deg) scale(${img.rotate === 90 || img.rotate === 270 ? 1.35 : 1})` : undefined} loading="lazy" />
            {img.date && <span class="sr-only">{formatGalleryDate(img.date, locale)}</span>}
          </a>
        );
      })}
    </div>
  </div>
</div>
