---
import type { Locale } from '../data/translations';
import { tNav } from '../data/translations';
interface Props {
  locale: Locale;
  current: string;
}

const { locale, current } = Astro.props;
const navItems = tNav(locale);
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
const base = locale === 'en' ? `${siteBase}/en` : siteBase;
const homeHref = base ? `${base}/` : '/';
const isEn = locale === 'en';
const activeClass = 'text-white font-semibold';
const inactiveClass = 'text-white/90 hover:text-white transition-colors font-medium';
---

<header class="header-bar sticky top-0 z-50" aria-label="Hlavná navigácia">
  <div class="max-w-[90rem] w-full mx-auto px-4 py-3 flex flex-wrap items-center justify-between gap-4">
    <a href={homeHref} class="flex items-center gap-2 font-display text-xl text-white font-semibold hover:text-white/95 transition-colors">
      <img src={`${siteBase || ''}/images/logo.svg`} alt="" class="header-logo h-9 w-auto" width="49" height="36" />
      <span>Tulipán</span>
    </a>
    <nav class="flex flex-wrap items-center gap-5" aria-label="Hlavná navigácia">
      <a href={homeHref} class={current === 'home' ? activeClass : inactiveClass}>{navItems.home}</a>
      <a href={`${base}/about`} class={current === 'about' ? activeClass : inactiveClass}>{navItems.about}</a>
      <a href={`${base}/events`} class={current === 'events' ? activeClass : inactiveClass}>{navItems.events}</a>
      <a href={`${base}/gallery`} class={current === 'gallery' ? activeClass : inactiveClass}>{navItems.gallery}</a>
      <a href={`${base}/contact`} class={current === 'contact' ? activeClass : inactiveClass}>{navItems.contact}</a>
      <a href={`${base}/contact#support`} class="inline-flex items-center px-3 py-1.5 rounded border border-white/60 text-white hover:bg-white/15 transition-colors font-medium text-sm">{navItems.support}</a>
      <a href={isEn ? (siteBase ? `${siteBase}/` : '/') : (siteBase ? `${siteBase}/en/` : '/en/')} class={`text-sm ${inactiveClass}`} hreflang={isEn ? 'sk' : 'en'} lang={isEn ? 'sk' : 'en'}>
        {isEn ? 'SK' : 'EN'}
      </a>
    </nav>
  </div>
</header>
