---
import type { Locale } from '../data/translations';
import { tFooter } from '../data/translations';
interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = tFooter(locale);
const siteBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
// Update these URLs if the group uses different social handles
const social = {
  facebook: 'https://www.facebook.com/tulipan.cataj',
  instagram: 'https://www.instagram.com/tulipan.cataj',
};
---

<footer class="footer-bar text-white/95 text-sm">
  <div class="max-w-[90rem] w-full mx-auto px-4 py-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
    <div class="flex flex-wrap items-center gap-4">
      <span class="font-medium text-white/90">{t.followUs}</span>
      <a
        href={social.facebook}
        target="_blank"
        rel="noopener noreferrer"
        class="text-white font-medium hover:underline transition-colors"
        aria-label={t.facebook}
      >
        {t.facebook}
      </a>
      <span class="text-white/50" aria-hidden="true">·</span>
      <a
        href={social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="text-white font-medium hover:underline transition-colors"
        aria-label={t.instagram}
      >
        {t.instagram}
      </a>
    </div>
    <p class="text-white/80 font-medium">{t.copyright}</p>
  </div>
</footer>
