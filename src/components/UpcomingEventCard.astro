---
import type { Locale } from '../data/translations';
import { upcomingEvent } from '../data/translations';

interface Props {
  locale: Locale;
  variant: 'teaser' | 'full';
  base?: string;
}
const { locale, variant, base = '' } = Astro.props;
const e = upcomingEvent[locale];
---

<article class="rounded-xl border-2 border-textile-gold/60 bg-white/95 shadow-lg overflow-hidden" aria-labelledby="upcoming-event-title">
  <div class="p-5 md:p-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-embroidery-red" aria-hidden="true">
      {locale === 'sk' ? 'Najbližšie podujatie' : 'Next event'}
    </p>
    <h2 id="upcoming-event-title" class="font-display text-xl md:text-2xl text-heritage-charcoal font-semibold mt-1">
      {e.title}
    </h2>
    <p class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-0 text-heritage-charcoal/90 font-medium">
      <time datetime={upcomingEvent.dateISO}>{e.dateLabel}</time>
      <span aria-hidden="true">·</span>
      <span>{e.place}</span>
    </p>
    {variant === 'teaser' ? (
      <p class="mt-3 text-heritage-charcoal/90 text-sm leading-relaxed max-w-2xl">
        {e.shortDescription}
      </p>
    ) : (
      <p class="mt-4 text-heritage-charcoal/90 leading-relaxed">
        {e.description}
      </p>
    )}
    {variant === 'teaser' && (
      <a
        href={`${base}/events`}
        class="btn-red mt-4 inline-block px-4 py-2 text-white font-semibold rounded-md transition-colors border border-white/20"
      >
        {e.cta}
      </a>
    )}
  </div>
</article>
