---
/**
 * Recreates the narrow separator bands from the embroidery reference:
 * golden-yellow band with white scalloped (wavy) top and bottom edges.
 * Pure SVG — no photo crop. Use as section divider.
 */
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 12 } = Astro.props;
---
<div class={`w-full overflow-hidden ${className}`} aria-hidden="true" role="presentation">
  <svg
    class="w-full block"
    viewBox="0 0 120 12"
    preserveAspectRatio="none"
    style={`height: ${height}px;`}
  >
    <defs>
      <linearGradient id="sep-band-gold" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#e5c76b" />
        <stop offset="50%" stop-color="#d4a017" />
        <stop offset="100%" stop-color="#b8860b" />
      </linearGradient>
      <!-- Repeating scallop: one period 20 units -->
      <path id="wave-top" d="M 0 4 Q 5 1 10 4 Q 15 7 20 4" fill="none" />
      <path id="wave-bot" d="M 0 8 Q 5 11 10 8 Q 15 5 20 8" fill="none" />
    </defs>
    <!-- Gold band -->
    <rect x="0" y="1" width="120" height="10" fill="url(#sep-band-gold)" />
    <!-- White scalloped edges: repeated waves -->
    <g stroke="#fffef9" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <path d="M 0 4 Q 5 1 10 4 Q 15 7 20 4 Q 25 1 30 4 Q 35 7 40 4 Q 45 1 50 4 Q 55 7 60 4 Q 65 1 70 4 Q 75 7 80 4 Q 85 1 90 4 Q 95 7 100 4 Q 105 1 110 4 Q 115 7 120 4" />
      <path d="M 0 8 Q 5 11 10 8 Q 15 5 20 8 Q 25 11 30 8 Q 35 5 40 8 Q 45 11 50 8 Q 55 5 60 8 Q 65 11 70 8 Q 75 5 80 8 Q 85 11 90 8 Q 95 5 100 8 Q 105 11 110 8 Q 115 5 120 8" />
    </g>
  </svg>
</div>
