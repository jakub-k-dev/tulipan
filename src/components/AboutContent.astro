---
import type { Locale } from '../data/translations';
import PageTextileHero from './PageTextileHero.astro';
import OrnamentDivider from './OrnamentDivider.astro';
import { tAbout } from '../data/translations';

interface Props {
  locale: Locale;
  siteBase: string;
}

const { locale, siteBase } = Astro.props;
const t = tAbout(locale);
---

<PageTextileHero title={t.title} />
<div class="bg-gradient-to-b from-textile-cream via-heritage-cream/30 to-textile-cream">
  <div class="max-w-[90rem] w-full mx-auto px-4 sm:px-6 py-14 sm:py-20">
    <OrnamentDivider variant="bar" class="max-w-[38rem] mx-auto mb-10 opacity-90" />
    <article class="max-w-[38rem] mx-auto rounded-2xl bg-white/90 shadow-lg shadow-heritage-charcoal/10 border border-textile-gold/30 overflow-hidden">
      <div class="p-6 sm:p-10 space-y-6 sm:space-y-7 pl-7 sm:pl-9 border-l-2 border-embroidery-red">
        {t.bodyParagraphs.map((paragraph) => (
          <p class="text-heritage-charcoal text-[1.05rem] leading-[1.75]">
            {paragraph}
          </p>
        ))}
      </div>
    </article>
    <OrnamentDivider variant="bar" class="max-w-[38rem] mx-auto mt-10 opacity-70" />
  </div>
</div>
