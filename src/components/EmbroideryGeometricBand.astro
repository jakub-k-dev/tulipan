---
/**
 * Recreates the central patterned band from the embroidery reference:
 * red/orange/gold background with repeating geometric motifs (squares, diamonds, crosses)
 * in white, blue, green, red. Pure SVG pattern — no photo crop.
 * Use as a strong section divider (e.g. below hero, between major sections).
 */
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 24 } = Astro.props;
---
<div class={`w-full overflow-hidden ${className}`} aria-hidden="true" role="presentation">
  <svg
    class="w-full block"
    viewBox="0 0 200 24"
    preserveAspectRatio="none"
    style={`height: ${height}px;`}
  >
    <defs>
      <linearGradient id="geom-band-bg" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#b91c1c" />
        <stop offset="30%" stop-color="#c2410c" />
        <stop offset="50%" stop-color="#d4a017" />
        <stop offset="70%" stop-color="#c2410c" />
        <stop offset="100%" stop-color="#7f1d1d" />
      </linearGradient>
      <!-- Repeating geometric unit: 10x10 grid cell with small shapes -->
      <pattern id="geom-pattern" x="0" y="0" width="10" height="10" patternUnits="userSpaceOnUse">
        <!-- Small square (white) -->
        <rect x="1" y="1" width="1.5" height="1.5" fill="#fffef9" opacity="0.95" />
        <!-- Diamond (blue) -->
        <path d="M 5 2 L 6 5 L 5 8 L 4 5 Z" fill="#3b82f6" opacity="0.9" />
        <!-- Cross (green) -->
        <rect x="7.2" y="3" width="0.8" height="4" fill="#22c55e" opacity="0.9" />
        <rect x="5.5" y="4.2" width="4" height="0.8" fill="#22c55e" opacity="0.9" />
        <!-- Small square (red) -->
        <rect x="1" y="6" width="1.2" height="1.2" fill="#b91c1c" opacity="0.85" />
        <!-- Diamond (white) -->
        <path d="M 5 6 L 6.2 8 L 5 10 L 3.8 8 Z" fill="#fffef9" opacity="0.7" />
      </pattern>
      <!-- White wavy top/bottom edges of the band -->
      <path id="geom-wave-t" d="M 0 2 Q 8 0 16 2 Q 24 4 32 2" fill="none" />
      <path id="geom-wave-b" d="M 0 22 Q 8 24 16 22 Q 24 20 32 22" fill="none" />
    </defs>
    <!-- Red/orange/gold band filled with geometric pattern -->
    <rect x="0" y="0" width="200" height="24" fill="url(#geom-band-bg)" />
    <rect x="0" y="0" width="200" height="24" fill="url(#geom-pattern)" />
    <!-- White scalloped edges -->
    <g stroke="#fffef9" stroke-width="0.8" fill="none" stroke-linecap="round">
      <path d="M 0 2 Q 10 0 20 2 Q 30 4 40 2 Q 50 0 60 2 Q 70 4 80 2 Q 90 0 100 2 Q 110 4 120 2 Q 130 0 140 2 Q 150 4 160 2 Q 170 0 180 2 Q 190 4 200 2" />
      <path d="M 0 22 Q 10 24 20 22 Q 30 20 40 22 Q 50 24 60 22 Q 70 20 80 22 Q 90 24 100 22 Q 110 20 120 22 Q 130 24 140 22 Q 150 20 160 22 Q 170 24 180 22 Q 190 20 200 22" />
    </g>
  </svg>
</div>
