---
/**
 * Minimal "two stripes" from the embroidery: two thin horizontal lines.
 * Flat, crisp. On cream use gold so visible; on dark use white.
 */
interface Props {
  class?: string;
  /** 'gold' on cream bg (default), 'white' on red/dark */
  variant?: 'gold' | 'white';
}
const { class: className = '', variant = 'gold' } = Astro.props;
const stroke = variant === 'white' ? '#fffef9' : '#b8860b';
---
<div class={`two-stripes-separator w-full ${className}`} aria-hidden="true" role="presentation">
  <svg class="w-full block" viewBox="0 0 100 4" preserveAspectRatio="none" style="height: 6px;">
    <line x1="0" y1="1" x2="100" y2="1" stroke={stroke} stroke-width="0.5" stroke-opacity={variant === 'gold' ? '0.7' : '1'} />
    <line x1="0" y1="3" x2="100" y2="3" stroke={stroke} stroke-width="0.5" stroke-opacity={variant === 'gold' ? '0.7' : '1'} />
  </svg>
</div>
