---
/** Lightbox: open image in modal on same page (no new tab). Include once per page that has a gallery grid. */
interface Props { siteBase?: string; }
const { siteBase = '' } = Astro.props;
---

<div id="gallery-lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-heritage-charcoal/90 p-4" role="dialog" aria-modal="true" aria-label="Lightbox">
  <button type="button" id="lightbox-close" class="absolute right-4 top-4 z-10 rounded-full bg-white/10 p-2 text-white hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white" aria-label="Close">
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>
  <button type="button" id="lightbox-prev" class="absolute left-2 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/10 p-2 text-white hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white sm:left-4" aria-label="Previous">
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
  </button>
  <button type="button" id="lightbox-next" class="absolute right-2 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/10 p-2 text-white hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white sm:right-4" aria-label="Next">
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
  </button>
  <div class="relative max-h-[85vh] max-w-[90vw]">
    <img id="lightbox-img" src="" alt="" class="max-h-[85vh] w-auto max-w-full object-contain" />
    <p id="lightbox-caption" class="mt-2 text-center text-sm text-white/80"></p>
  </div>
</div>

<script define:vars={{ siteBase }}>
  (function () {
    const base = typeof siteBase === 'string' ? siteBase : '';
    const lightbox = document.getElementById('gallery-lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const btnClose = document.getElementById('lightbox-close');
    const btnPrev = document.getElementById('lightbox-prev');
    const btnNext = document.getElementById('lightbox-next');

    if (!lightbox || !lightboxImg) return;

    let items = [];
    let currentIndex = 0;

    function show() {
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
      btnClose?.focus();
    }

    function hide() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function setImage(index) {
      if (index < 0 || index >= items.length) return;
      currentIndex = index;
      const item = items[index];
      const src = (item.src && item.src.startsWith('/')) ? base + item.src : item.src;
      lightboxImg.src = src;
      lightboxImg.alt = item.alt || '';
      if (lightboxCaption) lightboxCaption.textContent = item.alt || '';
      if (btnPrev) btnPrev.style.visibility = index === 0 ? 'hidden' : 'visible';
      if (btnNext) btnNext.style.visibility = index === items.length - 1 ? 'hidden' : 'visible';
    }

    function open(trigger) {
      const container = trigger.closest('[data-lightbox-container]');
      if (!container) return;
      const nodes = container.querySelectorAll('[data-lightbox-src]');
      items = Array.from(nodes).map((el) => ({
        src: el.getAttribute('data-lightbox-src'),
        alt: el.getAttribute('data-lightbox-alt') || '',
      })).filter((i) => i.src);
      if (items.length === 0) return;
      const idx = Array.from(nodes).indexOf(trigger);
      currentIndex = idx >= 0 ? idx : 0;
      setImage(currentIndex);
      show();
    }

    document.addEventListener('click', (e) => {
      const trigger = e.target.closest('[data-lightbox-src]');
      if (trigger && trigger.closest('[data-lightbox-container]')) {
        e.preventDefault();
        open(trigger);
      }
    });

    btnClose?.addEventListener('click', hide);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) hide(); });
    btnPrev?.addEventListener('click', () => { setImage(currentIndex - 1); });
    btnNext?.addEventListener('click', () => { setImage(currentIndex + 1); });

    document.addEventListener('keydown', (e) => {
      if (!lightbox || lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') hide();
      if (e.key === 'ArrowLeft') setImage(currentIndex - 1);
      if (e.key === 'ArrowRight') setImage(currentIndex + 1);
    });
  })();
</script>
