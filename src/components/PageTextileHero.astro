---
/** Page-level hero: large embroidery background with overlay and title */
interface Props {
  title: string;
  class?: string;
}
const { title, class: className = '' } = Astro.props;
---
<section class={`relative min-h-[40vh] flex items-end overflow-hidden ${className}`} aria-label={title}>
  <div class="absolute inset-0 bg-embroidery-full z-0" aria-hidden="true" />
  <div class="absolute inset-0 textile-overlay-dark z-10" aria-hidden="true" />
  <div class="relative z-20 w-full max-w-[90rem] w-full mx-auto px-4 py-16">
    <h1 class="font-display text-3xl md:text-4xl lg:text-5xl text-textile-outline font-semibold drop-shadow-md">
      {title}
    </h1>
  </div>
</section>
