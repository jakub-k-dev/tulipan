---
import type { Locale } from '../data/translations';
import PageTextileHero from './PageTextileHero.astro';
import { tContact } from '../data/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = tContact(locale);
---

<PageTextileHero title={t.title} />
<div class="bg-textile-cream">
  <div class="max-w-[90rem] w-full mx-auto px-4 py-12">
    <div class="text-heritage-charcoal pl-4 border-l-4 border-textile-gold space-y-4 max-w-xl">
      <p class="font-semibold text-heritage-charcoal text-lg">{t.name}</p>
      <div>
        <p class="text-sm font-medium text-heritage-charcoal/80">{t.contactPersonLabel}</p>
        <p class="font-medium mt-0.5">{t.contactPerson}</p>
      </div>
      <div>
        <p class="text-sm font-medium text-heritage-charcoal/80">{t.addressLabel}</p>
        <p class="font-medium mt-0.5">{t.address}</p>
      </div>
      <div>
        <p class="text-sm font-medium text-heritage-charcoal/80">{locale === 'sk' ? 'Telefón' : 'Phone'}</p>
        <p class="mt-0.5"><a href="tel:+421907747097" class="text-embroidery-red hover:underline font-medium">{t.phone}</a></p>
      </div>
      <div>
        <p class="text-sm font-medium text-heritage-charcoal/80">{locale === 'sk' ? 'E‑mail' : 'Email'}</p>
        <p class="mt-0.5"><a href={`mailto:${t.email}`} class="text-embroidery-red hover:underline font-medium">{t.email}</a></p>
      </div>
      <p class="text-sm text-heritage-charcoal/90 pt-1">{t.formNote}</p>
    </div>

    <section id="support" class="mt-14 pt-10 border-t border-textile-gold/40 scroll-mt-24" aria-labelledby="support-heading">
      <h2 id="support-heading" class="font-display text-xl text-heritage-charcoal font-semibold">{t.supportTitle}</h2>
      <p class="mt-2 text-heritage-charcoal/90">{t.supportIntro}</p>
      <p class="mt-3 font-mono text-lg font-semibold text-embroidery-red tracking-wide" dir="ltr">SK93 7500 0000 0040 3474 6255</p>
    </section>
  </div>
</div>
