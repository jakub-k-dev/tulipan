---
/**
 * Section divider: two thin stripes (from embroidery band edges).
 * Flat, minimal. For the full strip use EmbroideryStrip.
 */
import TwoStripesSeparator from './TwoStripesSeparator.astro';
interface Props {
  class?: string;
  /** 'gold' on cream (default), 'white' on red/dark (e.g. header/footer) */
  variant?: 'gold' | 'white';
}
const { class: className = '', variant = 'gold' } = Astro.props;
---
<TwoStripesSeparator class={className} variant={variant} />
